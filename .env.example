# Copy this file to .env and add your real key.
NVIDIA_API_KEY=nvapi-your-key-here

# fast = local EasyOCR only
# hybrid = EasyOCR first, NVIDIA model only if local OCR sees nothing
# ai = NVIDIA model for every changed screenshot
OCR_ENGINE=hybrid

NVIDIA_MODEL=mistralai/ministral-14b-instruct-2512
AI_TIMEOUT_SECONDS=2.5
AI_MAX_TOKENS=32
LOOP_DELAY_SECONDS=0.25
